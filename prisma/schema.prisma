generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CropType {
  id                   Int       @id @default(autoincrement())
  crop_name            String
  variety              String?
  base_temp_gdd        Float?
  target_gdd_harvest   Float?
  spray_wind_limit_kmh Float?
  spray_humidity_max   Float?
  spray_humidity_min   Float?
  spray_temp_min       Float?
  spray_temp_max       Float?
  frost_alert_temp     Float?
  frost_critical_stage String?
  notes                String?
  stations             Station[]
  @@map("crop_types")
}

model Farmer {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  email         String    @unique
  password_hash String
  tier          String    @default("base")
  active        Boolean   @default(true)
  created_at    DateTime  @default(now())
  agronomist_name    String?
  agronomist_company String?
  agronomist_phone   String?
  stations      Station[]
  agronomists   Agronomist[]
  @@map("farmers")
}

model Agronomist {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  password_hash     String
  farmer_id         String    @db.Uuid
  farmer            Farmer    @relation(fields: [farmer_id], references: [id], onDelete: Cascade)
  active            Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@map("agronomists")
}

model Station {
  id                  String    @id
  farmer_id           String    @db.Uuid
  paddock_name        String?
  hectares            Float?
  crop_type_id        Int?
  planted_date        DateTime?
  growth_stage        String?
  soil_type           String?   @default("loam")
  target_yield_t_ha   Float?
  farm_name           String?
  farm_address        String?
  latitude            Float?
  longitude           Float?
  elevation_m         Float?
  installation_date   DateTime?
  paddock_notes       String?
  is_virtual          Boolean?  @default(false)
  sim_phone_number    String?
  sim_provider        String?
  sim_activation_date DateTime?
  sim_imei            String?
  bom_station_id      String?
  bom_station_name    String?
  bom_last_reading_time DateTime?
  bom_temp_c          Float?
  bom_humidity_pct    Float?
  bom_wind_speed_kmh  Float?
  bom_wind_direction  String?
  spray_wind_override Float?
  frost_temp_override Float?
  created_at          DateTime  @default(now())
  farmer              Farmer    @relation(fields: [farmer_id], references: [id])
  crop_type           CropType? @relation(fields: [crop_type_id], references: [id])
  weather_readings    WeatherReading[]
  @@map("stations")
}

model WeatherReading {
  id            Int      @id @default(autoincrement())
  created_at    DateTime @default(now())
  station_id    String
  temperature_c Float?
  humidity      Float?
  wind_dir_deg  Float?
  wind_avg_ms   Float?
  wind_max_ms   Float?
  rain_mm       Float?
  uvi           Float?
  light_lux     Float?
  battery_mv    Float?
  rssi          Int?
  station       Station  @relation(fields: [station_id], references: [id])
  @@map("weather_readings")
}
